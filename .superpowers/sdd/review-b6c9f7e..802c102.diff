+    <p class="hero-subtitle animate-fade-in-delay-2">{{ tr().home.hero.subtitle }}</p>
+    <div class="hero-actions animate-fade-in-delay-3">
+      <a routerLink="/uslugi" class="btn btn-primary">{{ tr().home.hero.cta1 }}</a>
